# ============================================================
#  EXAM TRACKER — Python Backend Environment Variables
#  Copy this file to .env and fill in your values
# ============================================================

# Supabase credentials (Dashboard → Project → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY      # Service Role key (not anon) — for backend use only
SUPABASE_JWT_SECRET=YOUR_JWT_SECRET             # Dashboard → Settings → API → JWT Secret

# Server config
PORT=8000
ENV=development

# CORS — set to your frontend URL
FRONTEND_URL=http://127.0.0.1:5500
